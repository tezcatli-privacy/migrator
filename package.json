{
  "name": "tezcatli-migrator",
  "version": "0.3.1",
  "description": "Tezcatli step-1 wallet migrator built on the Fhenix CoFHE starter",
  "scripts": {
    "test": "hardhat test",
    "test:gas": "REPORT_GAS=true hardhat test",
    "clean": "rimraf ./artifacts ./cache ./coverage ./types ./coverage.json ./deployments/localcofhe",
    "compile": "hardhat compile",
    "task:deploy": "hardhat deploy-migrator-stack",
    "task:dust-swap-demo": "hardhat dust-swap-demo",
    "task:migrate-demo": "hardhat migrate-demo",
    "localcofhe:start": "hardhat localcofhe:start --clean true",
    "localcofhe:test": "hardhat test --network localcofhe",
    "localcofhe:test:gas": "REPORT_GAS=true hardhat test --network localcofhe",
    "localcofhe:faucet": "hardhat task:cofhe:usefaucet --network localcofhe",
    "localcofhe:deploy": "hardhat deploy-migrator-stack --network localcofhe",
    "localcofhe:stop": "hardhat localcofhe:stop",
    "eth-sepolia:deploy-migrator": "hardhat deploy-migrator-stack --network eth-sepolia",
    "arb-sepolia:deploy-migrator": "hardhat deploy-migrator-stack --network arb-sepolia",
    "base-sepolia:deploy-migrator": "hardhat deploy-migrator-stack --network base-sepolia"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fhenixprotocol/cofhe-hardhat-starter.git"
  },
  "author": "Fhenix",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/fhenixprotocol/cofhe-hardhat-starter/issues"
  },
  "homepage": "https://github.com/fhenixprotocol/cofhe-hardhat-starter#readme",
  "devDependencies": {
    "@fhenixprotocol/cofhe-contracts": "^0.1.3",
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-ignition": "^0.15.0",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.0",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@openzeppelin/contracts": "^5.0.0",
    "@openzeppelin/contracts-upgradeable": "^5.0.0",
    "@typechain/ethers-v6": "^0.5.0",
    "@typechain/hardhat": "^9.0.0",
    "@types/chai": "^4.2.0",
    "@types/mocha": ">=9.1.0",
    "@types/node": ">=18.0.0",
    "chai": "^4.2.0",
    "@cofhe/hardhat-plugin": "^0.4.0",
    "@cofhe/sdk": "^0.4.0",
    "@cofhe/mock-contracts": "^0.4.0",
    "dotenv": "^16.4.7",
    "ethers": "^6.4.0",
    "fhenix-confidential-contracts": "^0.2.1",
    "hardhat": "^2.22.19",
    "hardhat-gas-reporter": "^1.0.8",
    "solidity-coverage": "^0.8.0",
    "ts-node": ">=8.0.0",
    "typechain": "^8.3.0",
    "typescript": ">=4.5.0"
  }
}
